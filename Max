import java.util.Scanner;

public class Max {
   
   public int findMax() {
      Scanner scnr = new Scanner(System.in);
      int num;
      int max = 0;

      num = scnr.nextInt();

      while (num >= 0) {
        if (num > max) {
            max = num;
        }
        num = scnr.nextInt();
      } 
      return max;
   }
   
   public static void main(String[] args) {
      Max test = new Max();
      System.out.println(test.findMax());
   }
}
